{
  "name": "yggdrasil-forge",
  "version": "0.0.0",
  "private": true,
  "description": "Comprehensive skill tree engine and visual editor for the web",
  "license": "MIT",
  "author": "Agarfal",
  "homepage": "https://github.com/cancioneschorriscortas-max/yggdrasil-forge",
  "repository": {
    "type": "git",
    "url": "https://github.com/cancioneschorriscortas-max/yggdrasil-forge.git"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "fresh": "pnpm clean && pnpm install",
    "validate": "pnpm lint && pnpm typecheck && pnpm test",
    "check-env": "node scripts/check-env.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  }
}

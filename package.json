{
  "name": "yggdrasil-forge",
  "version": "0.0.0",
  "private": true,
  "description": "Comprehensive skill tree engine and visual editor for the web",
  "license": "MIT",
  "author": "Agarfal",
  "homepage": "https://github.com/cancioneschorriscortas-max/yggdrasil-forge",
  "repository": {
    "type": "git",
    "url": "https://github.com/cancioneschorriscortas-max/yggdrasil-forge.git"
  },
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='!./examples/*'",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "turbo run typecheck",
    "typecheck:packages": "turbo run typecheck --filter='!./examples/*'",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "fresh": "pnpm clean && pnpm install",
    "validate": "pnpm lint && pnpm typecheck && pnpm test",
    "check-env": "node scripts/check-env.mjs",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version && pnpm install --lockfile-only --no-frozen-lockfile --config.link-workspace-packages=true",
    "changeset:publish": "pnpm build:packages && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  }
}
